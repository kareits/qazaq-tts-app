# Site address from the env var SITE_ADDRESS (default :80).
# For production set a domain (e.g. tts.example.kz) — Caddy obtains HTTPS itself.
{$SITE_ADDRESS::80} {
	encode gzip

	# API → backend. The full /api/... path is preserved (not stripped).
	# flush_interval -1 disables response buffering — important for SSE
	# (/api/tts/stream).
	@api path /api/*
	handle @api {
		reverse_proxy backend:8000 {
			flush_interval -1
		}
	}

	# SPA: serve static assets, route unknown paths to index.html.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
