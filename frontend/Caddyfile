# Адрес сайта из env SITE_ADDRESS (по умолчанию :80).
# Для прода задать домен (напр. tts.example.kz) — Caddy сам получит HTTPS.
{$SITE_ADDRESS::80} {
	encode gzip

	# API → backend. Полный путь /api/... сохраняется (не strip).
	# flush_interval -1 отключает буферизацию — важно для SSE (/api/tts/stream).
	@api path /api/*
	handle @api {
		reverse_proxy backend:8000 {
			flush_interval -1
		}
	}

	# SPA: отдаём статику, неизвестные пути → index.html.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
