# Конфигурация docker-compose (скопировать в .env и отредактировать).

# Адрес сайта для Caddy:
#   :80         — локально без HTTPS
#   tts.example.kz — домен в проде (Caddy сам выпустит HTTPS-сертификат)
SITE_ADDRESS=:80

# Порты хоста
HTTP_PORT=80
HTTPS_PORT=443

# Голос по умолчанию (предзагружается при старте backend)
DEFAULT_VOICE=female1
