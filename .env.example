# docker-compose configuration (copy to .env and edit).

# Site address for Caddy:
#   :80            — local, without HTTPS
#   tts.example.kz — a domain in production (Caddy issues an HTTPS certificate)
SITE_ADDRESS=:80

# Host ports
HTTP_PORT=80
HTTPS_PORT=443

# Default voice (preloaded at backend startup)
DEFAULT_VOICE=female1
